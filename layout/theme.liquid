<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-ui-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

    {{ content_for_header }}

    {%- style -%}
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-background: {{ settings.color_background }};
        --color-text: {{ settings.color_text }};
        --color-button: {{ settings.color_button }};
        --color-button-text: {{ settings.color_button_text }};

        --font-heading-family: "Cormorant Garamond", serif;
        --font-heading-style: normal;
        --font-heading-weight: 500;

        --font-body-family: "Manrope", sans-serif;
        --font-body-style: normal;
        --font-body-weight: 400;

        --page-width: {{ settings.page_width | append: 'px' }};
        --spacing-grid-horizontal: {{ settings.spacing_grid_horizontal | append: 'px' }};
        --spacing-grid-vertical: {{ settings.spacing_grid_vertical | append: 'px' }};
        
        --button-border-radius: {{ settings.button_border_radius | append: 'px' }};
      }

    {%- endstyle -%}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- if settings.custom_head_scripts != blank -%}
      {{ settings.custom_head_scripts }}
    {%- endif -%}

    {%- if settings.custom_css != blank -%}
      <style>
        {{ settings.custom_css }}
      </style>
    {%- endif -%}

    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "Organization",
        "name": {{ shop.name | json }},
        {% if settings.logo %}
          "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
        {% endif %}
        "sameAs": [
          {{ settings.social_instagram_url | json }},
          {{ settings.social_facebook_url | json }},
          {{ settings.social_pinterest_url | json }},
          {{ settings.social_youtube_url | json }},
          {{ settings.social_linkedin_url | json }},
          {{ settings.social_twitter_url | json }},
          {{ settings.social_tiktok_url | json }}
        ],
        "url": {{ request.origin | append: page.url | json }}
      }
    </script>
  </head>

  <body class="template-{{ template.name | handle }}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_text" | t }}
    </a>

    <div class="header-group-wrapper {% if template.name == 'index' %}is-transparent-on-home{% endif %}">
      {% section 'announcement-bar' %}
      {% section 'header' %}
    </div>

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {% section 'cart-drawer' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };
    </script>

    {%- if settings.custom_footer_scripts != blank -%}
      {{ settings.custom_footer_scripts }}
    {%- endif -%}

    {% render 'mobile-bottom-nav' %}
  </body>
</html>

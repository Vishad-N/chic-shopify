<div class="featured-collections section-padding bg-texture" style="background-color: {{ section.settings.color_bg }};">
  {% render 'botanical-divider' %}
  {% render 'botanical-corner', class: 'corner-top-right' %}
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading text-center">
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="grid grid--2-col grid--4-col featured-collections__grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <div class="grid__item" {{ block.shopify_attributes }}>
          <a href="{% if collection != blank %}{{ collection.url }}{% else %}#{% endif %}" class="collection-card">
            <div class="collection-card__image-wrapper" style="border-radius: {{ section.settings.image_radius }}px; overflow: hidden;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="600" height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}">
              {%- elsif collection != blank and collection.image != blank -%}
                <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy" width="600" height="{{ 600 | divided_by: collection.image.aspect_ratio | round }}">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <div class="collection-card__overlay"></div>
            </div>
            <div class="collection-card__content">
              <h3 class="collection-card__title">
                {%- if block.settings.heading != blank -%}
                  {{ block.settings.heading | escape }}
                {%- elsif collection != blank -%}
                  {{ collection.title }}
                {%- else -%}
                  Collection title
                {%- endif -%}
              </h3>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .section-heading {
    margin-bottom: 3rem;
  }
  .section-heading h2 {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1.5rem;
  }
  .collection-card {
    display: block;
    position: relative;
    text-decoration: none;
    color: var(--color-text);
  }
  .collection-card__image-wrapper {
    position: relative;
    aspect-ratio: 4 / 5;
    background-color: rgba(0,0,0,0.05);
  }
  .collection-card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .collection-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 30%); /* Much more subtle just to ground it */
    pointer-events: none;
  }
  .collection-card:hover .collection-card__image-wrapper img {
    transform: scale(1.05);
  }
  .collection-card__content {
    position: absolute;
    bottom: 24px;
    left: 0;
    width: 100%;
    padding: 0 1rem;
    display: flex;
    justify-content: center;
  }
  .collection-card__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 500;
    font-family: 'Cormorant Garamond', serif;
    color: #2C2A28;
    background-color: rgba(250, 247, 242, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 10px 24px;
    border-radius: 999px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    border: 1px solid rgba(255,255,255,0.6);
    text-align: center;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  .collection-card:hover .collection-card__title {
    background-color: rgba(255, 255, 255, 0.98);
    transform: translateY(-2px);
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Featured Collections",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#f9f6f0"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Image border radius"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides collection image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Custom Heading",
          "info": "Overrides collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

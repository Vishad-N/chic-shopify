<div class="testimonials section-padding bg-texture" style="background-color: {{ section.settings.color_bg }}; position: relative; overflow: hidden;">
  {% render 'botanical-corner', class: 'corner-top-left' %}
  {% render 'botanical-corner', class: 'corner-bottom-right' %}
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading text-center">
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="slider-wrapper">
      <ul class="testimonial-slider grid grid--3-col" role="list">
        {%- for block in section.blocks -%}
          <li class="grid__item slider__slide" {{ block.shopify_attributes }}>
            <div class="testimonial-card text-center" style="border-radius: {{ section.settings.card_radius }}px;">
              <div class="testimonial-card__image">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 100 }}" alt="{{ block.settings.author | escape }}" loading="lazy" width="60" height="60">
                {%- else -%}
                  <div class="testimonial-card__avatar-placeholder"></div>
                {%- endif -%}
              </div>
              <div class="testimonial-card__rating">
                {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
              </div>
              <div class="testimonial-card__quote">
                "{{ block.settings.quote | escape }}"
              </div>
              <h4 class="testimonial-card__author">{{ block.settings.author | escape }}</h4>
              {%- if block.settings.location != blank -%}
                <p class="testimonial-card__location">{{ block.settings.location | escape }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

<style>
  .testimonials .section-heading h2 {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1.5rem;
    margin-bottom: 3rem;
  }
  .testimonial-slider {
    display: flex;
    flex-wrap: nowrap;
    margin: 0;
    padding: 0 0 1rem 0;
    gap: var(--spacing-grid-horizontal);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .testimonial-slider::-webkit-scrollbar {
    display: none;
  }
  .testimonial-slider .slider__slide {
    flex: 0 0 calc(33.333% - var(--spacing-grid-horizontal));
    scroll-snap-align: start;
  }
  @media screen and (max-width: 989px) {
    .testimonial-slider .slider__slide {
      flex: 0 0 calc(50% - var(--spacing-grid-horizontal));
    }
  }
  @media screen and (max-width: 749px) {
    .testimonial-slider .slider__slide {
      flex: 0 0 calc(85% - var(--spacing-grid-horizontal));
    }
  }
  .testimonial-card {
    background-color: #fff;
    padding: 3rem 2rem;
    height: 100%;
    border: 1px solid rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .testimonial-card__image img {
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }
  .testimonial-card__avatar-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: var(--color-secondary);
    margin-bottom: 1rem;
    opacity: 0.5;
  }
  .testimonial-card__rating {
    color: var(--color-primary);
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
  }
  .testimonial-card__quote {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.4;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }
  .testimonial-card__author {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }
  .testimonial-card__location {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "TESTIMONIALS",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#f9f6f0"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Card border radius"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Rating"
        },
        {
          "type": "textarea",
          "id": "quote",
          "default": "Natural, luxurious, and deeply hydrating.",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Sarah M.",
          "label": "Author Name"
        },
        {
          "type": "text",
          "id": "location",
          "default": "Verified Buyer",
          "label": "Location / Status"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}

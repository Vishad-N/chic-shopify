<div class="best-sellers section-padding bg-texture" style="background-color: {{ section.settings.color_bg }};">
  {% render 'botanical-divider' %}
  <div class="page-width">
    <div class="section-heading text-center">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="slider-wrapper">
      {% render 'botanical-vine' %}
      <ul class="product-slider grid grid--4-col" role="list" style="position: relative; z-index: 1;">
        {%- assign collection = section.settings.collection -%}
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            <li class="grid__item slider__slide">
              {% render 'product-card', product: product, show_secondary_image: section.settings.show_secondary_image, show_vendor: section.settings.show_vendor, show_rating: section.settings.show_rating %}
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <li class="grid__item slider__slide">
              <div class="product-card placeholder">
                <div class="product-card__image-wrapper" style="border-radius: 120px 120px 0 0;">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <div class="product-card__info">
                  <h3 class="product-card__title">Example Product</h3>
                  <div class="product-card__price">$19.99</div>
                </div>
              </div>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </div>
  </div>
</div>

<style>
  .best-sellers .section-heading {
    margin-bottom: 3rem;
  }
  .best-sellers .subheading {
    margin-top: -1rem;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }
  .slider-wrapper {
    position: relative;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
  }
  .slider-wrapper::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }
  .product-slider {
    display: flex;
    flex-wrap: nowrap;
    margin: 0;
    padding: 0 0 1rem 0;
    gap: var(--spacing-grid-horizontal);
  }
  .slider__slide {
    flex: 0 0 calc(25% - var(--spacing-grid-horizontal));
    scroll-snap-align: start;
  }
  @media screen and (max-width: 989px) {
    .slider__slide {
      flex: 0 0 calc(33.333% - var(--spacing-grid-horizontal));
    }
  }
  @media screen and (max-width: 749px) {
    .slider__slide {
      flex: 0 0 calc(60% - var(--spacing-grid-horizontal));
    }
  }
</style>

{% schema %}
{
  "name": "Best Sellers Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Best Sellers",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Premium product slider",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Maximum products to show"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#f9f6f0"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers Slider"
    }
  ]
}
{% endschema %}

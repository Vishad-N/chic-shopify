<div class="hero hero--{{ section.settings.hero_height }}" style="background-color: {{ section.settings.color_bg }};">
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | image_url: width: 2000 }}" 
         alt="{{ section.settings.image.alt | escape }}" 
         class="hero__image hero__image--desktop" 
         loading="eager" 
         width="2000" 
         height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}">
    
    {%- if section.settings.image_mobile != blank -%}
      <img src="{{ section.settings.image_mobile | image_url: width: 800 }}" 
           alt="{{ section.settings.image_mobile.alt | escape }}" 
           class="hero__image hero__image--mobile" 
           loading="eager" 
           width="800" 
           height="{{ 800 | divided_by: section.settings.image_mobile.aspect_ratio | round }}">
    {%- endif -%}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__image placeholder-svg' }}
  {%- endif -%}

  <div class="hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; background-color: #000;"></div>

  <div class="hero__content-wrapper page-width">
    <div class="hero__content {{ section.settings.content_alignment }}">
      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading" style="color: {{ section.settings.color_text }};">
          {{ section.settings.heading | escape }}
        </h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="hero__subheading" style="color: {{ section.settings.color_text }};">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      <div class="hero__buttons">
        {%- if section.settings.button_1_label != blank -%}
          <a href="{{ section.settings.button_1_link }}" class="button">
            {{ section.settings.button_1_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank -%}
          <a href="{{ section.settings.button_2_link }}" class="button button--secondary" style="color: {{ section.settings.color_text }}; border-color: {{ section.settings.color_text }};">
            {{ section.settings.button_2_label | escape }} &rarr;
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero--small { height: 50vh; }
  .hero--medium { height: 75vh; }
  .hero--large { height: 100vh; }
  
  .hero__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }
  .hero__image--mobile {
    display: none;
  }
  {%- if section.settings.image_mobile != blank -%}
    @media screen and (max-width: 749px) {
      .hero__image--desktop { display: none; }
      .hero__image--mobile { display: block; }
    }
  {%- endif -%}

  .hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }
  .hero__content-wrapper {
    position: relative;
    z-index: 3;
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .hero__content {
    max-width: 800px;
    padding: 2rem;
  }
  .hero__content.text-center {
    text-align: center;
    align-items: center;
    display: flex;
    flex-direction: column;
  }
  .hero__content.text-left {
    text-align: left;
    margin-right: auto;
  }
  .hero__content.text-right {
    text-align: right;
    margin-left: auto;
  }
  .hero__heading {
    margin-bottom: 1rem;
    font-size: clamp(32px, 5vw, 64px);
    line-height: 1.1;
  }
  .hero__subheading {
    margin-bottom: 2rem;
    font-size: 1.125rem;
  }
  .hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero__content.text-center .hero__buttons {
    justify-content: center;
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image (optional)"
    },
    {
      "type": "select",
      "id": "hero_height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large (Fullscreen)" }
      ],
      "default": "medium",
      "label": "Section height"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "label": "Overlay opacity"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Luxury Botanical Beauty Crafted by Nature",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "default": "<p>Pure botanical skincare rituals inspired by nature and perfected with science.</p>",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-center",
      "label": "Content alignment"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "default": "Shop Collection",
      "label": "Button 1 label"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "default": "Discover Our Story",
      "label": "Button 2 label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

<header-component class="header {% if section.settings.enable_sticky_header %}header--sticky{% endif %} {% if section.settings.transparent_on_home and template.name == 'index' %}header--transparent{% endif %}" style="background-color: {{ section.settings.color_bg }};">
  <div class="page-width">
    <!-- DESKTOP HEADER -->
    <div class="header__inner header__desktop-layout">
      {%- if section.settings.logo_position == 'left' -%}
        <div class="header__logo">
          <a href="{{ routes.root_url }}">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto" loading="eager">
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}

      <nav class="header__inline-menu">
        <ul class="list-menu list-menu--inline" role="list">
          {%- for link in section.settings.menu.links -%}
            <li>
              <a href="{{ link.url }}" class="header__menu-item list-menu__item link link--text focus-inset" {% if link.current %} aria-current="page"{% endif %}>
                <span {%- if link.current %} class="header__active-menu-item"{% endif %}>{{ link.title | escape }}</span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      {%- if section.settings.logo_position == 'center' -%}
        <div class="header__logo header__logo--center">
          <a href="{{ routes.root_url }}">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto" loading="eager">
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}

      <div class="header__icons">
        <a href="{{ routes.search_url }}" class="header__icon header__icon--search link focus-inset">
          {% render 'icon-search' %}
        </a>

        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset">
            {% render 'icon-account' %}
          </a>
        {%- endif -%}

        <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble" onclick="event.preventDefault(); document.querySelector('cart-drawer').open();">
          {% render 'icon-cart' %}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        </a>
      </div>
    </div>

    <!-- MOBILE HEADER -->
    <div class="header__inner header__mobile-layout">
      <!-- Hamburger Menu Toggle -->
      <button type="button" class="header__icon header__icon--menu mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <!-- Center Logo -->
      <div class="header__logo header__logo--mobile">
        <a href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 120 }}" alt="{{ shop.name }}" class="mobile-logo-img" loading="eager">
          {%- else -%}
            <span class="h2">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Right Icons (Cart) -->
      <div class="header__icons">
        <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" onclick="event.preventDefault(); document.querySelector('cart-drawer').open();">
          {% render 'icon-cart' %}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</header-component>

<!-- MOBILE FULLSCREEN SLIDE-IN NAVIGATION -->
<div class="mobile-nav-panel" aria-hidden="true">
  <div class="mobile-nav-panel__overlay mobile-menu-toggle"></div>
  <div class="mobile-nav-panel__content">
    <div class="mobile-nav-panel__header">
      <button type="button" class="header__icon header__icon--close mobile-menu-toggle" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <ul class="mobile-nav-panel__menu">
      <li><a href="{{ routes.root_url }}" class="mobile-nav-panel__link">Home</a></li>
      <li><a href="/collections/all" class="mobile-nav-panel__link">Shop</a></li>
      <li><a href="/collections/skin-care" class="mobile-nav-panel__link">Skin Care</a></li>
      <li><a href="/collections/hair-care" class="mobile-nav-panel__link">Hair Care</a></li>
      <li><a href="/collections/body-care" class="mobile-nav-panel__link">Body Care</a></li>
      <li><a href="/collections/gift-sets" class="mobile-nav-panel__link">Gift Sets</a></li>
      <li><a href="/pages/ingredients" class="mobile-nav-panel__link">Ingredients</a></li>
      <li><a href="/blogs/journal" class="mobile-nav-panel__link">Journal</a></li>
      <li><a href="/pages/about" class="mobile-nav-panel__link">About</a></li>
      <li><a href="/pages/contact" class="mobile-nav-panel__link">Contact</a></li>
    </ul>
  </div>
</div>

<style>
  /* ========================================================
     DESKTOP HEADER DEFAULT STYLES
     ======================================================== */
  .header {
    padding: 20px 0;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease, transform 0.4s ease, color 0.4s ease;
    z-index: 100;
    width: 100%;
  }
  .header.is-scrolled {
    position: fixed;
    top: 0;
    left: 0;
    background-color: rgba(250, 247, 242, 0.95) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    animation: slideDown 0.4s ease;
  }
  @keyframes slideDown {
    from { transform: translateY(-100%); }
    to { transform: translateY(0); }
  }
  .header--transparent {
    background-color: transparent !important;
  }
  .header--transparent .header__menu-item,
  .header--transparent .header__icon {
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }
  .header.is-scrolled .header__menu-item,
  .header.is-scrolled .header__icon {
    color: #2F342C;
    text-shadow: none;
  }
  
  .header__menu-item {
    font-family: var(--font-body-family);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    position: relative;
    padding: 8px 0;
    transition: color 0.25s ease;
  }
  .header__menu-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 100%;
    height: 1px;
    background-color: #5F715A;
    transition: transform 0.25s ease;
    transform-origin: center;
  }
  .header__menu-item:hover,
  .header__active-menu-item {
    color: #5F715A !important;
  }
  .header__menu-item:hover::after,
  .header__active-menu-item::after {
    transform: translateX(-50%) scaleX(1);
  }
  
  .header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .header__inline-menu {
    flex: 1;
    display: flex;
    justify-content: flex-start;
  }
  .list-menu--inline {
    display: flex;
    gap: 2rem;
  }
  .header__icons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .header__icon {
    position: relative;
    color: var(--color-text);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .header__icon svg {
    width: 24px;
    height: 24px;
  }
  .cart-count-bubble {
    position: absolute;
    top: -5px;
    right: -10px;
    background: #5F715A;
    color: #fff;
    font-size: 10px;
    border-radius: 50%;
    width: 16px;
    height: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .header__logo--center {
    flex: 1;
    text-align: center;
  }

  /* ========================================================
     MOBILE LAYOUT
     ======================================================== */
  .header__mobile-layout {
    display: none;
  }
  .mobile-nav-panel {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .header__desktop-layout {
      display: none !important;
    }
    
    .header {
      padding: 16px 0;
      height: 72px; /* Enforced mobile header height */
    }

    .header__mobile-layout {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      height: 100%;
      padding: 0;
      position: relative; /* Added for absolute centering of logo */
    }

    /* Fixed logo size on mobile */
    .header__logo--mobile {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
    }
    .mobile-logo-img {
      width: 110px;
      height: auto;
      display: block;
    }

    /* Mobile Icons hover override */
    .header__icon {
      color: #39463A; /* Botanical Green base for icons */
      transition: color 0.3s ease;
    }
    .header__icon:hover {
      color: #5F715A;
    }
    /* Ensure icons in transparent header start white, unless scrolled */
    .header--transparent:not(.is-scrolled) .header__icon {
      color: #FFFFFF;
    }

    /* Slide-in Menu Panel */
    .mobile-nav-panel {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100svh; /* use safe height */
      z-index: 9999;
      pointer-events: none; /* Let clicks pass through when closed */
    }

    .mobile-nav-panel[aria-hidden="false"] {
      pointer-events: auto;
    }

    .mobile-nav-panel__overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background-color: rgba(0,0,0,0.4);
      opacity: 0;
      transition: opacity 0.4s ease;
    }
    
    .mobile-nav-panel[aria-hidden="false"] .mobile-nav-panel__overlay {
      opacity: 1;
    }

    .mobile-nav-panel__content {
      position: absolute;
      top: 0;
      left: -100%;
      width: 85%;
      max-width: 320px;
      height: 100%;
      background-color: #FAF7F2; /* Cream brand background */
      box-shadow: 10px 0 30px rgba(0,0,0,0.1);
      transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
      display: flex;
      flex-direction: column;
      padding: 24px;
      overflow-y: auto;
    }

    .mobile-nav-panel[aria-hidden="false"] .mobile-nav-panel__content {
      transform: translateX(100%);
    }

    .mobile-nav-panel__header {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 40px;
    }

    .mobile-nav-panel__menu {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .mobile-nav-panel__link {
      font-family: 'Cormorant Garamond', serif;
      font-size: 24px;
      color: #2C2A28;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s ease;
      display: block;
    }
    .mobile-nav-panel__link:hover,
    .mobile-nav-panel__link:active {
      color: #5F715A;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Mobile slide-in menu logic
    const menuToggles = document.querySelectorAll('.mobile-menu-toggle');
    const navPanel = document.querySelector('.mobile-nav-panel');

    if (navPanel) {
      menuToggles.forEach(toggle => {
        toggle.addEventListener('click', () => {
          const isExpanded = navPanel.getAttribute('aria-hidden') === 'false';
          if (isExpanded) {
            navPanel.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
          } else {
            navPanel.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden'; // Prevent background scrolling
          }
        });
      });
    }

    // Scroll effect (shared for desktop and mobile)
    const header = document.querySelector('.header');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header.classList.add('is-scrolled');
        } else {
          header.classList.remove('is-scrolled');
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Custom logo width"
    },
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center",
      "label": "Logo position"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header",
      "default": true,
      "label": "Enable sticky header"
    },
    {
      "type": "checkbox",
      "id": "transparent_on_home",
      "default": true,
      "label": "Enable transparent header on homepage"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#f9f6f0"
    }
  ]
}
{% endschema %}

<div class="page-policy section-padding">
  <div class="page-width page-width--narrow">
    <header class="page-policy__header text-center">
      <h1 class="page-policy__title">Shipping Policy</h1>
    </header>

    <div class="page-policy__content">
      <section class="page-policy__block">
        <ul>
          <li>Processing Time: Orders are processed within 2–3 business days.</li>
          <li>Shipping Time: Standard shipping usually takes 5–7 business days. Expedited options may be available at checkout.</li>
          <li>Shipping Charges: Calculated at checkout based on your location and shipping method.</li>
          <li>Order Tracking: A tracking number will be provided once your order is shipped.</li>
          <li>Shipping Issues: For lost or delayed packages, please contact our Customer Support at <a href="mailto:chicthebotanicalbeauty@gmail.com">chicthebotanicalbeauty@gmail.com</a>.</li>
        </ul>
      </section>
    </div>
  </div>
</div>

<style>
  .page-policy {
    padding: 8rem 0;
    color: var(--color-text);
  }
  .page-policy__header {
    margin-bottom: 5rem;
  }
  .page-policy__title {
    font-family: var(--font-heading-family);
    font-size: clamp(3rem, 4vw, 4rem);
    color: #2F342C;
    margin-bottom: 1rem;
  }
  .page-policy__date {
    font-size: 1.4rem;
    color: #5F715A;
    font-family: var(--font-body-family);
  }
  .page-policy__block {
    margin-bottom: 4rem;
  }
  .page-policy__heading {
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
    color: #2F342C;
    margin-bottom: 1.5rem;
  }
  .page-policy__content p, .page-policy__content ul, .page-policy__content li {
    font-size: 1.5rem;
    line-height: 1.8;
    color: rgba(47, 52, 44, 0.8);
    margin-bottom: 1.5rem;
  }
  .page-policy__content ul {
    list-style-type: disc;
    padding-left: 2rem;
  }
  .page-policy__content li {
    margin-bottom: 0.8rem;
  }
  .page-policy__content a {
    color: #5F715A;
    text-decoration: underline;
  }
  .page-policy__content a:hover {
    color: #2F342C;
  }
  
  @media screen and (max-width: 768px) {
    .page-policy {
      padding: 5rem 0;
    }
    .page-policy__header {
      margin-bottom: 3rem;
    }
    .page-policy__block {
      margin-bottom: 3rem;
    }
  }
</style>

{% schema %}
{
  "name": "Shipping Policy",
  "settings": []
}
{% endschema %}

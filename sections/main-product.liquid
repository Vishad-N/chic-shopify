<div class="product section-padding page-width" data-section-id="{{ section.id }}">
  <div class="product__grid grid grid--2-col">
    <!-- Media Gallery (Sticky) -->
    <div class="grid__item product__media-wrapper">
      <div class="product__media-sticky">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media -%}
            <div class="product__media-item" data-media-id="{{ media.id }}">
              {% case media.media_type %}
                {% when 'image' %}
                  <img src="{{ media | image_url: width: 1000 }}" alt="{{ media.alt | escape }}" loading="lazy" width="1000" height="{{ 1000 | divided_by: media.aspect_ratio | round }}">
                {% when 'video' %}
                  {{ media | video_tag: controls: true, class: 'media-video' }}
                {% when 'external_video' %}
                  {{ media | external_video_tag }}
                {% when 'model' %}
                  {{ media | model_viewer_tag }}
              {% endcase %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <!-- Product Info -->
    <div class="grid__item product__info-wrapper">
      <div class="product__info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}

            {%- when 'text' -%}
              <p class="product__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>

            {%- when 'title' -%}
              <h1 class="product__title" {{ block.shopify_attributes }}>{{ product.title | escape }}</h1>

            {%- when 'price' -%}
              <div class="product__price" {{ block.shopify_attributes }}>
                <span class="price-item price-item--regular" id="price-{{ section.id }}">
                  {{ product.price | money }}
                </span>
                {%- if product.compare_at_price > product.price -%}
                  <s class="price-item price-item--sale">{{ product.compare_at_price | money }}</s>
                {%- endif -%}
              </div>

            {%- when 'variant_picker' -%}
              {%- unless product.has_only_default_variant -%}
                <variant-radios class="product__variants" data-section="{{ section.id }}" data-url="{{ product.url }}" {{ block.shopify_attributes }}>
                  {%- for option in product.options_with_values -%}
                    <fieldset class="js product-form__input">
                      <legend class="form__label">{{ option.name }}</legend>
                      {%- for value in option.values -%}
                        <input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                              name="{{ option.name }}"
                              value="{{ value | escape }}"
                              form="product-form-{{ section.id }}"
                              {% if option.selected_value == value %}checked{% endif %}
                        >
                        <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                          {{ value }}
                        </label>
                      {%- endfor -%}
                    </fieldset>
                  {%- endfor -%}
                  <script type="application/json">
                    {{ product.variants | json }}
                  </script>
                </variant-radios>
              {%- endunless -%}

            {%- when 'quantity_selector' -%}
              <div class="product-form__input product-form__quantity" {{ block.shopify_attributes }}>
                <label class="form__label" for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
                <input class="quantity__input" type="number" name="quantity" id="Quantity-{{ section.id }}" min="1" value="1" form="product-form-{{ section.id }}">
              </div>

            {%- when 'buy_buttons' -%}
              <div class="product__buy-buttons" {{ block.shopify_attributes }}>
                {%- form 'product', product, id: 'product-form-{{ section.id }}', class: 'form' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" class="button button--primary product-form__submit"
                    {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                    {%- if product.selected_or_first_available_variant.available -%}
                      {{ 'products.product.add_to_cart' | t }}
                    {%- else -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- endif -%}
                  </button>
                  {%- if block.settings.show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                {%- endform -%}
              </div>

            {%- when 'description' -%}
              <div class="product__description rte" {{ block.shopify_attributes }}>
                {{ product.description }}
              </div>
              
            {%- when 'accordion' -%}
              <details class="product__accordion" {{ block.shopify_attributes }}>
                <summary>
                  <div class="summary__title">{{ block.settings.heading | escape }}</div>
                  <div class="summary__icon">+</div>
                </summary>
                <div class="accordion__content rte">
                  {{ block.settings.content }}
                  {%- if block.settings.page != blank -%}
                    {{ block.settings.page.content }}
                  {%- endif -%}
                </div>
              </details>
              
            {%- when 'inventory_status' -%}
              {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                <div class="product__inventory" {{ block.shopify_attributes }}>
                  {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                    <span class="inventory--in-stock">In stock ({{ product.selected_or_first_available_variant.inventory_quantity }})</span>
                  {%- else -%}
                    <span class="inventory--out-of-stock">Out of stock</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<style>
  .product__grid {
    gap: 4rem;
  }
  .product__media-sticky {
    position: sticky;
    top: 100px;
  }
  .product__media-item {
    margin-bottom: 1rem;
    border-radius: {{ settings.button_border_radius }}px;
    overflow: hidden;
    background: rgba(0,0,0,0.02);
  }
  .product__info {
    position: sticky;
    top: 100px;
  }
  .product__title {
    font-size: clamp(2rem, 3vw, 3rem);
    margin-bottom: 1rem;
  }
  .product__price {
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }
  .price-item--sale {
    opacity: 0.5;
    margin-left: 0.5rem;
  }
  .product-form__input {
    margin-bottom: 1.5rem;
    border: none;
    padding: 0;
  }
  .product-form__input legend {
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .product-form__input input[type="radio"] {
    display: none;
  }
  .product-form__input input[type="radio"] + label {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-text);
    border-radius: {{ settings.button_border_radius }}px;
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
    cursor: pointer;
  }
  .product-form__input input[type="radio"]:checked + label {
    background-color: var(--color-text);
    color: var(--color-background);
  }
  .quantity__input {
    padding: 1rem;
    width: 100px;
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: {{ settings.button_border_radius }}px;
    background: transparent;
    font-family: inherit;
  }
  .product-form__submit {
    width: 100%;
    margin-bottom: 1rem;
  }
  .shopify-payment-button__button {
    border-radius: {{ settings.button_border_radius }}px !important;
  }
  .product__accordion {
    border-top: 1px solid rgba(0,0,0,0.1);
  }
  .product__accordion:last-child {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .product__accordion summary {
    display: flex;
    justify-content: space-between;
    padding: 1.5rem 0;
    cursor: pointer;
    font-size: 1.125rem;
    list-style: none;
  }
  .product__accordion summary::-webkit-details-marker {
    display: none;
  }
  .accordion__content {
    padding-bottom: 1.5rem;
    color: rgba(0,0,0,0.7);
  }
  .inventory--in-stock { color: green; font-size: 0.9rem;}
  .inventory--out-of-stock { color: red; font-size: 0.9rem;}
</style>

{% schema %}
{
  "name": "Product Information",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1
    },
    {
      "type": "quantity_selector",
      "name": "Quantity selector",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "Show dynamic checkout buttons"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Details",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Page content"
        }
      ]
    },
    {
      "type": "inventory_status",
      "name": "Inventory Status",
      "limit": 1
    }
  ]
}
{% endschema %}

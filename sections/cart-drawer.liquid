<cart-drawer class="drawer {% if cart == empty %}is-empty{% endif %}">
  <div id="CartDrawer-Overlay" class="drawer__overlay"></div>
  <div class="drawer__inner" role="dialog" aria-modal="true" aria-label="{{ 'sections.cart.title' | t }}" tabindex="-1">
    <div class="drawer__header">
      <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
      <button class="drawer__close button button--secondary" type="button" aria-label="{{ 'accessibility.close' | t }}">
        ✕
      </button>
    </div>

    <cart-drawer-items class="drawer__items" {% if cart == empty %}class="is-empty"{% endif %}>
      <form action="{{ routes.cart_url }}" id="CartDrawer-Form" class="cart__contents cart-drawer__form" method="post">
        <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
          {%- if cart != empty -%}
            <table class="cart-items" role="table">
              <thead role="rowgroup">
                <tr role="row">
                  <th id="CartDrawer-ColumnProductImage" role="columnheader"><span class="visually-hidden">{{ 'sections.cart.headings.product' | t }}</span></th>
                  <th id="CartDrawer-ColumnProduct" role="columnheader" scope="col">{{ 'sections.cart.headings.product' | t }}</th>
                  <th id="CartDrawer-ColumnTotal" role="columnheader" scope="col">{{ 'sections.cart.headings.total' | t }}</th>
                  <th id="CartDrawer-ColumnQuantity" role="columnheader" scope="col"><span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span></th>
                </tr>
              </thead>

              <tbody role="rowgroup">
                {%- for item in cart.items -%}
                  <tr id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cart-item" role="row">
                    <td class="cart-item__media" role="cell" headers="CartDrawer-ColumnProductImage">
                      {% if item.image %}
                        <img class="cart-item__image" src="{{ item.image | image_url: width: 300 }}" alt="{{ item.image.alt | escape }}" loading="lazy" width="150" height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}">
                      {% endif %}
                    </td>
                    <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                      <a href="{{ item.url }}" class="cart-item__name link link--text">{{ item.product.title | escape }}</a>
                      {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                        <dl>
                          {%- if item.product.has_only_default_variant == false -%}
                            {%- for option in item.options_with_values -%}
                              <div class="product-option">
                                <dt>{{ option.name }}: </dt>
                                <dd>{{ option.value }}</dd>
                              </div>
                            {%- endfor -%}
                          {%- endif -%}
                        </dl>
                      {%- endif -%}
                      <div class="cart-item__price-wrapper">
                        {{ item.original_price | money }}
                      </div>
                    </td>
                    <td class="cart-item__quantity" role="cell" headers="CartDrawer-ColumnQuantity">
                      <div class="cart-item__quantity-wrapper">
                        <label class="visually-hidden" for="Drawer-quantity-{{ item.index | plus: 1 }}">
                          {{ 'products.product.quantity.label' | t }}
                        </label>
                        <input class="quantity__input" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}" id="Drawer-quantity-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                        <a href="{{ item.url_to_remove }}" class="button button--secondary cart-remove-button" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}">
                          Remove
                        </a>
                      </div>
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- endif -%}
        </div>
      </form>
    </cart-drawer-items>

    <div class="drawer__footer">
      <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
        <div class="totals" role="status">
          <h3 class="totals__subtotal">{{ 'sections.cart.subtotal' | t }}</h3>
          <p class="totals__subtotal-value">{{ cart.total_price | money_with_currency }}</p>
        </div>
        <small class="tax-note caption-large rte">
          {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
            {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
          {%- elsif cart.taxes_included -%}
            {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
          {%- elsif shop.shipping_policy.body != blank -%}
            {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
          {%- else -%}
            {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
          {%- endif -%}
        </small>
        <div class="cart__ctas">
          <button type="submit" id="CartDrawer-Checkout" class="cart__checkout-button button" name="checkout" form="CartDrawer-Form" {% if cart == empty %}disabled{% endif %}>
            {{ 'sections.cart.checkout' | t }}
          </button>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<style>
  .drawer {
    visibility: hidden;
  }
  .drawer.is-active {
    visibility: visible;
  }
  .drawer__overlay {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    background-color: rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 999;
  }
  .drawer.is-active .drawer__overlay {
    opacity: 1;
  }
  .drawer__inner {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 400px;
    max-width: 100vw;
    background-color: var(--color-background);
    z-index: 1000;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .drawer.is-active .drawer__inner {
    transform: translateX(0);
  }
  .drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .drawer__heading {
    margin: 0;
    font-size: 1.5rem;
  }
  .drawer__close {
    border: none;
    background: transparent;
    font-size: 1.5rem;
    padding: 0;
    width: 40px;
    height: 40px;
  }
  .drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
  }
  .cart-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .cart-item__media {
    width: 80px;
    flex-shrink: 0;
  }
  .cart-item__image {
    width: 100%;
    height: auto;
    border-radius: {{ settings.button_border_radius }}px;
  }
  .cart-item__details {
    flex: 1;
  }
  .cart-item__name {
    display: block;
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  .product-option {
    font-size: 0.8rem;
    opacity: 0.7;
    display: flex;
  }
  .cart-item__quantity-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .cart-item__quantity-wrapper .quantity__input {
    width: 60px;
    padding: 0.25rem 0.5rem;
  }
  .cart-remove-button {
    font-size: 0.8rem;
    padding: 0;
    border: none;
    text-transform: none;
  }
  .drawer__footer {
    padding: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.1);
    background-color: var(--color-background);
  }
  .totals {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .totals__subtotal {
    margin: 0;
    font-size: 1.25rem;
  }
  .totals__subtotal-value {
    margin: 0;
    font-size: 1.25rem;
    font-weight: bold;
  }
  .cart__checkout-button {
    width: 100%;
    margin-top: 1.5rem;
  }
</style>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}

<div class="instagram-feed section-padding bg-texture" style="background-color: {{ section.settings.color_bg }};">
  <div class="page-width" style="position: relative; z-index: 1;">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading text-center">
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="instagram-grid" style="--gap: {{ section.settings.grid_gap }}px; --radius: {{ section.settings.image_radius }}px;">
      {%- for block in section.blocks -%}
        <div class="instagram-grid__item" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" class="instagram-card" target="_blank" rel="noopener">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="Instagram image" loading="lazy" width="400" height="400">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            <div class="instagram-card__overlay">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .instagram-feed .section-heading h2 {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1.5rem;
    margin-bottom: 3rem;
  }
  .instagram-feed {
    position: relative;
    overflow: hidden;
  }
  .instagram-feed::before,
  .instagram-feed::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 150px;
    height: 300px;
    background-repeat: no-repeat;
    background-size: contain;
    opacity: 0.03;
    pointer-events: none;
    z-index: 0;
  }
  .instagram-feed::before {
    left: -20px;
    transform: translateY(-50%);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 200C50 150 100 50 100 0' stroke='%235F715A' stroke-width='2' fill='none'/%3E%3Cpath d='M50 150C70 140 80 160 50 150Z' fill='%235F715A'/%3E%3Cpath d='M80 80C100 70 100 90 80 80Z' fill='%235F715A'/%3E%3C/svg%3E");
  }
  .instagram-feed::after {
    right: -20px;
    transform: translateY(-50%) scaleX(-1);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 200C50 150 100 50 100 0' stroke='%235F715A' stroke-width='2' fill='none'/%3E%3Cpath d='M50 150C70 140 80 160 50 150Z' fill='%235F715A'/%3E%3Cpath d='M80 80C100 70 100 90 80 80Z' fill='%235F715A'/%3E%3C/svg%3E");
  }
  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--gap);
  }
  @media screen and (max-width: 989px) {
    .instagram-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media screen and (max-width: 749px) {
    .instagram-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .instagram-card {
    display: block;
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius);
    background-color: rgba(0,0,0,0.05);
  }
  .instagram-card img, .instagram-card svg.placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .instagram-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.3);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .instagram-card:hover img {
    transform: scale(1.05);
  }
  .instagram-card:hover .instagram-card__overlay {
    opacity: 1;
  }
</style>

{% schema %}
{
  "name": "Instagram Feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "INSTAGRAM",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#f9f6f0"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Space between images"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Image border radius"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}

{% comment %}
  Accepts:
  - product: {Object} Product Liquid object
  - show_secondary_image: {Boolean} Show the secondary image on hover
  - show_vendor: {Boolean} Show the product vendor
  - show_rating: {Boolean} Show the product rating
{% endcomment %}

<div class="product-card">
  <a href="{{ product.url | within: collection }}" class="product-card__link">
    <div class="product-card__image-wrapper" style="border-radius: {{ settings.button_border_radius }}px;">
      {%- if product.featured_media -%}
        <img src="{{ product.featured_media | image_url: width: 533 }}" 
             alt="{{ product.featured_media.alt | escape }}" 
             class="product-card__image" 
             loading="lazy" 
             width="533" 
             height="{{ 533 | divided_by: product.featured_media.aspect_ratio | round }}">
        
        {%- if show_secondary_image and product.media[1] != nil -%}
          <img src="{{ product.media[1] | image_url: width: 533 }}" 
               alt="{{ product.media[1].alt | escape }}" 
               class="product-card__image product-card__image--secondary" 
               loading="lazy" 
               width="533" 
               height="{{ 533 | divided_by: product.media[1].aspect_ratio | round }}">
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
      {%- endif -%}

      {%- if product.available == false -%}
        <span class="badge badge--soldout">{{ 'products.product.sold_out' | t }}</span>
      {%- elsif product.compare_at_price > product.price -%}
        <span class="badge badge--sale">Sale</span>
      {%- endif -%}
    </div>

    <div class="product-card__info">
      {%- if show_vendor -%}
        <div class="product-card__vendor">{{ product.vendor }}</div>
      {%- endif -%}
      
      <h3 class="product-card__title">{{ product.title | escape }}</h3>
      
      {%- if show_rating and product.metafields.reviews.rating.value != blank -%}
        <div class="product-card__rating">
          <!-- Render stars based on rating -->
          ★★★★★
        </div>
      {%- endif -%}

      <div class="product-card__price">
        {%- if product.compare_at_price > product.price -%}
          <s class="price-item--regular">{{ product.compare_at_price | money }}</s>
          <span class="price-item--sale">{{ product.price | money }}</span>
        {%- else -%}
          <span class="price-item--regular">{{ product.price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>
  <div class="product-card__actions">
    <button type="button" class="product-card__quick-add link link--text" data-product-id="{{ product.id }}">
      + Quick Add
    </button>
    <button type="button" class="product-card__wishlist link link--text">
      ♡ Wishlist
    </button>
  </div>
</div>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    text-align: left;
    height: 100%;
  }
  .product-card__link {
    text-decoration: none;
    color: inherit;
    flex-grow: 1;
  }
  .product-card__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    margin-bottom: 1rem;
    border-radius: 120px 120px 0 0; /* botanical arch style */
  }
  .product-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }
  .product-card__image--secondary {
    opacity: 0;
  }
  .product-card:hover .product-card__image--secondary {
    opacity: 1;
  }
  .badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #000;
    color: #fff;
    padding: 4px 8px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge--sale { background: var(--color-secondary); }
  
  .product-card__title {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
    font-family: var(--font-heading-family);
  }
  .product-card__vendor {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    margin-bottom: 0.25rem;
  }
  .product-card__price {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .price-item--regular { opacity: 0.6; margin-right: 0.5rem; }
  .price-item--sale { color: var(--color-primary); }
  
  .product-card__actions {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
    border-top: 1px solid rgba(0,0,0,0.1);
    padding-top: 0.5rem;
  }
  .product-card__actions button {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    text-transform: inherit;
    letter-spacing: inherit;
    padding: 0;
    color: var(--color-text);
  }
</style>

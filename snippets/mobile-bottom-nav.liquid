<nav class="mobile-bottom-nav" aria-label="Mobile Navigation">
  <div class="mobile-bottom-nav__inner">
    
    <a href="{{ routes.root_url }}" class="mobile-bottom-nav__item {% if request.path == routes.root_url %}is-active{% endif %}" aria-label="Home">
      <span class="mobile-bottom-nav__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </span>
      <span class="mobile-bottom-nav__label">Home</span>
    </a>

    <a href="{{ routes.all_products_collection_url }}" class="mobile-bottom-nav__item {% if request.path contains '/collections' or request.path contains '/products' %}is-active{% endif %}" aria-label="Shop">
      <span class="mobile-bottom-nav__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </span>
      <span class="mobile-bottom-nav__label">Shop</span>
    </a>

    <a href="{{ routes.root_url }}#skincare-ritual" class="mobile-bottom-nav__item mobile-nav-ritual-link" aria-label="Ritual">
      <span class="mobile-bottom-nav__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22C12 22 17 17 17 12C17 7 12 2 12 2C12 2 7 7 7 12C7 17 12 22 12 22Z"></path>
          <path d="M12 22V12"></path>
        </svg>
      </span>
      <span class="mobile-bottom-nav__label">Ritual</span>
    </a>

    <a href="{{ routes.cart_url }}" class="mobile-bottom-nav__item {% if request.path == routes.cart_url %}is-active{% endif %}" aria-label="Cart" onclick="event.preventDefault(); if(document.querySelector('cart-drawer')){ document.querySelector('cart-drawer').open(); } else { window.location.href='{{ routes.cart_url }}'; }">
      <span class="mobile-bottom-nav__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
      </span>
      <span class="mobile-bottom-nav__label">Cart</span>
    </a>

  </div>
</nav>

<style>
  .mobile-bottom-nav {
    display: none;
  }
  
  @media screen and (max-width: 768px) {
    .mobile-bottom-nav {
      display: flex;
      justify-content: center;
      position: fixed;
      bottom: calc(16px + env(safe-area-inset-bottom));
      left: 50%;
      transform: translateX(-50%);
      width: 92%;
      max-width: 420px;
      height: 68px;
      border-radius: 999px;
      background-color: rgba(250,247,242,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(95,113,90,0.12);
      box-shadow: 0 15px 40px rgba(0,0,0,0.08);
      z-index: 990; /* Below popups but above content */
    }

    .mobile-bottom-nav__inner {
      display: flex;
      width: 100%;
      height: 100%;
      justify-content: space-around;
      align-items: center;
      padding: 0 10px;
    }

    .mobile-bottom-nav__item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: #39463A;
      height: 100%;
      min-width: 44px; /* Accessible touch target */
      position: relative;
      -webkit-tap-highlight-color: transparent;
      padding-top: 4px; /* Slight offset for centering visually */
    }

    /* Active Underline */
    .mobile-bottom-nav__item::after {
      content: '';
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%) scaleX(0);
      width: 20px;
      height: 2px;
      background-color: #5F715A; /* Botanical Green */
      border-radius: 2px;
      transition: transform 0.25s ease;
    }

    .mobile-bottom-nav__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.25s ease, color 0.25s ease;
      margin-bottom: 2px;
    }

    .mobile-bottom-nav__label {
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 500;
      transition: color 0.25s ease;
      line-height: 1;
    }

    /* Active and Hover States */
    .mobile-bottom-nav__item.is-active,
    .mobile-bottom-nav__item:hover {
      color: #5F715A;
    }

    .mobile-bottom-nav__item.is-active::after {
      transform: translateX(-50%) scaleX(1);
    }

    .mobile-bottom-nav__item.is-active .mobile-bottom-nav__icon,
    .mobile-bottom-nav__item:active .mobile-bottom-nav__icon {
      transform: translateY(-2px);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Smooth scrolling for ritual link if already on homepage
    const ritualLink = document.querySelector('.mobile-nav-ritual-link');
    
    if (ritualLink) {
      ritualLink.addEventListener('click', (e) => {
        if (window.location.pathname === '{{ routes.root_url }}' || window.location.pathname === '/') {
          const target = document.querySelector('.skincare-ritual');
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth' });
            
            // Manually set active state
            document.querySelectorAll('.mobile-bottom-nav__item').forEach(item => item.classList.remove('is-active'));
            ritualLink.classList.add('is-active');
          }
        }
      });
    }

    // Basic Intersection observer to highlight ritual link when in view on homepage
    if (window.location.pathname === '{{ routes.root_url }}' || window.location.pathname === '/') {
      const ritualSection = document.querySelector('.skincare-ritual');
      const navItems = document.querySelectorAll('.mobile-bottom-nav__item');
      
      if (ritualSection && ritualLink) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              navItems.forEach(item => item.classList.remove('is-active'));
              ritualLink.classList.add('is-active');
            }
          });
        }, { threshold: 0.3 });
        
        observer.observe(ritualSection);
      }
    }
  });
</script>

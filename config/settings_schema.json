[
  {
    "name": "theme_info",
    "theme_name": "CHIC Botanical Beauty",
    "theme_author": "Developer",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://help.shopify.com",
    "theme_support_url": "https://help.shopify.com"
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width_desktop",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo Width (Desktop)",
        "default": 150
      },
      {
        "type": "range",
        "id": "logo_width_mobile",
        "min": 50,
        "max": 200,
        "step": 10,
        "unit": "px",
        "label": "Logo Width (Mobile)",
        "default": 100
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_url",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_facebook_url",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "social_pinterest_url",
        "label": "Pinterest URL"
      },
      {
        "type": "url",
        "id": "social_youtube_url",
        "label": "YouTube URL"
      },
      {
        "type": "url",
        "id": "social_linkedin_url",
        "label": "LinkedIn URL"
      },
      {
        "type": "url",
        "id": "social_twitter_url",
        "label": "X (Twitter) URL"
      },
      {
        "type": "url",
        "id": "social_tiktok_url",
        "label": "TikTok URL"
      }
    ]
  },
  {
    "name": "Custom Code",
    "settings": [
      {
        "type": "textarea",
        "id": "custom_css",
        "label": "Custom CSS",
        "info": "Add custom CSS here. Do not include <style> tags."
      },
      {
        "type": "textarea",
        "id": "custom_head_scripts",
        "label": "Custom Head Scripts",
        "info": "Add scripts to be injected in the <head> of the document. Include <script> tags."
      },
      {
        "type": "textarea",
        "id": "custom_footer_scripts",
        "label": "Custom Footer Scripts",
        "info": "Add scripts to be injected before the closing </body> tag. Include <script> tags."
      }
    ]
  }
]
